# PostgreSQL — matches docker-compose.yml (postgres/postgres, db havyn)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/havyn?schema=public"

# Auth.js — required in production (`openssl rand -base64 32`). Optional locally: a dev fallback is used when unset.
AUTH_SECRET=""

# Google OAuth (optional — omit in dev if you use DEV_* bypass below)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Absolute site URL for prospect links in emails/adapters (e.g. http://localhost:3000)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Dev auth bypass — `npm run db:seed` writes these to .env.local when present. Only honored when NODE_ENV=development.
DEV_ORGANIZATION_ID=""
DEV_USER_ID=""

# AI copilot — heuristics always run; set true + OpenAI key for optional LLM overlay (falls back on errors)
ENABLE_AI_SUGGESTIONS="false"
OPENAI_API_KEY=""
# Optional model override for copilot summary/draft (default: gpt-4o-mini)
OPENAI_COPILOT_MODEL=""

# Resend — transactional email for owned-channel automation (optional locally)
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# Twilio — transactional SMS for owned-channel automation (optional locally)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Inngest — background jobs (use dev server locally: npx inngest-cli@latest dev)
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# S3 uploads for listing photos (AWS S3 or compatible providers)
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Optional for S3-compatible providers (R2, DO Spaces)
S3_ENDPOINT=""
# Optional CDN/public base URL. If omitted, falls back to bucket host URL.
S3_PUBLIC_URL=""
