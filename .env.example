# PostgreSQL — matches docker-compose.yml (postgres/postgres, db havyn)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/havyn?schema=public"

# Supabase Auth (required for login)
# Use the same project URL for both server + browser contexts.
SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Only needed for one-time admin operations (user provisioning/reset scripts).
SUPABASE_SERVICE_ROLE_KEY=""

# Default invited login for seeded demo flow:
#   email: havynrecruiting@gmail.com
#   password: test123
# On first successful login, the app ensures this account has an org membership.

# Absolute site URL for prospect links in emails/adapters (e.g. http://localhost:3000)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Dev auth bypass — `npm run db:seed` writes these to .env.local when present. Only honored when NODE_ENV=development.
DEV_ORGANIZATION_ID=""
DEV_USER_ID=""

# AI copilot — heuristics always run; set true + OpenAI key for optional LLM overlay (falls back on errors)
ENABLE_AI_SUGGESTIONS="false"
OPENAI_API_KEY=""
# Optional model override for copilot summary/draft (default: gpt-4o-mini)
OPENAI_COPILOT_MODEL=""

# Resend — transactional email for owned-channel automation (optional locally)
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# Twilio — transactional SMS for owned-channel automation (optional locally)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Inngest — background jobs (use dev server locally: npx inngest-cli@latest dev)
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# S3 uploads for listing photos (AWS S3 or compatible providers)
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Optional for S3-compatible providers (R2, DO Spaces)
S3_ENDPOINT=""
# Optional CDN/public base URL. If omitted, falls back to bucket host URL.
S3_PUBLIC_URL=""

# Zillow rental bulk feed (https://s3.amazonaws.com/files.hotpads.com/+guides/Rental+Listing+Bulk+Feed+Guide.pdf)
# Zillow fetches GET /api/feeds/zillow-rental on a schedule when enabled.
ZILLOW_RENTAL_FEED_ENABLED="false"
# Required when enabled: organization id (cuid) to export
ZILLOW_RENTAL_FEED_ORG_ID=""
# Optional: require ?token= or Authorization: Bearer (share via secure channel with Zillow)
ZILLOW_RENTAL_FEED_TOKEN=""
# Required when enabled: syndication contact for every listing
ZILLOW_RENTAL_FEED_CONTACT_NAME=""
ZILLOW_RENTAL_FEED_CONTACT_EMAIL=""
ZILLOW_RENTAL_FEED_CONTACT_PHONE=""
# Company block in XML: use if org has no ACTIVE listing to infer city/state from
ZILLOW_RENTAL_FEED_COMPANY_CITY=""
ZILLOW_RENTAL_FEED_COMPANY_STATE=""
# Optional overrides
ZILLOW_RENTAL_FEED_COMPANY_WEBSITE=""
ZILLOW_RENTAL_FEED_COMPANY_LOGO_URL=""

# Google Calendar integration
GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""
